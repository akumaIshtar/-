; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="项目-全局"
run/main_scene="uid://vkux0elhi6cd"
config/features=PackedStringArray("4.4", "Forward Plus")
boot_splash/bg_color=Color(1, 1, 1, 1)
boot_splash/minimum_display_time=1000

[autoload]

GameData="*res://Scene/Game/Global/game_data.tscn"
SignalBus="*res://Script/Game/Global/signal_bus.gd"
FreezeFrameManager="*res://Script/Game/Global/freeze_frame_manager.gd"
Music="*res://audio/music.tscn"
PanelManager="*res://Scene/Game/Global/panel_manager.tscn"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"

[debug]

settings/physics_interpolation/enable_warnings=false

[display]

window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

[global_group]

enemies=""
global_world_map=""

[gui]

theme/custom_font="uid://xkneq0iar0rr"

