op_type = 5

[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 BackgroundColor : source_color;
uniform vec4 BorderColor : source_color;
uniform float MixProgress : hint_range(0.0, 0.5);



void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = BackgroundColor;


// ColorParameter:4
	vec4 n_out4p0 = BorderColor;


// Input:10
	vec2 n_out10p0 = UV;


// FloatParameter:5
	float n_out5p0 = MixProgress;


	float n_out6p0;
// Expression:6
	n_out6p0 = 0.0;
	{
		float dis = max(abs(n_out10p0.x - 0.5), abs(n_out10p0.y - 0.5));
		if (dis < 0.5 - n_out5p0)
		{
			n_out6p0 = 1.0;
		}else{
			n_out6p0 = 1.0 - pow((dis + n_out5p0 - 0.5) / n_out5p0 ,3);
		}
	}


// Mix:7
	vec4 n_out7p0 = mix(n_out2p0, n_out4p0, vec4(n_out6p0));
	float n_out7p1 = n_out7p0.r;
	float n_out7p2 = n_out7p0.g;
	float n_out7p3 = n_out7p0.b;
	float n_out7p4 = n_out7p0.a;


// VectorCompose:11
	vec3 n_out11p0 = vec3(n_out7p1, n_out7p2, n_out7p3);


// Output:0
	COLOR.rgb = n_out11p0;
	COLOR.a = n_out7p4;


}
