[sub_resource type="VisualShaderNodeMix" id="VisualShaderNodeMix_2w1ib"]
default_input_values = [0, Quaternion(0, 0, 0, 0), 1, Quaternion(1, 1, 1, 1), 2, Quaternion(0.5, 0.5, 0.5, 0.5)]
