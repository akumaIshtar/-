code = "shader_type canvas_item;
render_mode blend_mul;

uniform vec4 EffectColor : source_color;
uniform float Radius;
uniform float Speed;
uniform sampler2D Texture1;
uniform sampler2D Texture2;
uniform float Mix_Speed;



void fragment() {
// ColorParameter:24
	vec4 n_out24p0 = EffectColor;
	float n_out24p1 = n_out24p0.r;
	float n_out24p2 = n_out24p0.g;
	float n_out24p3 = n_out24p0.b;


// VectorCompose:60
	vec3 n_out60p0 = vec3(n_out24p1, n_out24p2, n_out24p3);


// Input:6
	vec2 n_out6p0 = UV;


// VectorOp:35
	vec2 n_in35p1 = vec2(0.50000, 0.50000);
	vec2 n_out35p0 = n_out6p0 - n_in35p1;


// FloatParameter:2
	float n_out2p0 = Radius;


// VectorCompose:38
	vec2 n_out38p0 = vec2(n_out2p0, n_out2p0);


// VectorOp:37
	vec2 n_out37p0 = n_out35p0 * n_out38p0;


// VectorLen:9
	float n_out9p0 = length(n_out37p0);


// FloatOp:10
	float n_in10p1 = 2.00000;
	float n_out10p0 = n_out9p0 * n_in10p1;


// FloatOp:11
	float n_in11p1 = 3.00000;
	float n_out11p0 = n_out10p0 * n_in11p1;


// FloatOp:12
	float n_in12p0 = 3.00000;
	float n_out12p0 = n_in12p0 - n_out11p0;


// VectorFunc:36
	vec2 n_out36p0 = atan(n_out37p0);


// FloatOp:18
	float n_in18p1 = 6.28300;
	float n_out18p0 = n_out36p0.x / n_in18p1;


// FloatOp:19
	float n_in19p1 = 0.50000;
	float n_out19p0 = n_out18p0 + n_in19p1;


// VectorLen:21
	float n_out21p0 = length(n_out37p0);


// FloatConstant:22
	float n_out22p0 = 0.500000;


// VectorCompose:20
	vec3 n_out20p0 = vec3(n_out19p0, n_out21p0, n_out22p0);


// Input:13
	float n_out13p0 = TIME;


// FloatParameter:3
	float n_out3p0 = Speed;


// FloatOp:14
	float n_out14p0 = n_out13p0 / n_out3p0;


// FloatOp:15
	float n_in15p1 = -1.00000;
	float n_out15p0 = n_out14p0 * n_in15p1;


	float n_out34p0;
// Expression:34
	n_out34p0 = 0.0;
	{
		for (int i = 1; i <= 7; i++) 
		{
			float power = pow(2.0, float(i));
			
			float f1;
			float res = power * 16.0;
			vec3 uv = n_out20p0 + vec3(0.0, -n_out15p0 * 0.05, n_out15p0 * 0.01);
			
			const vec3 s = vec3(1e0, 1e2, 1e3);
		    uv *= res;
		    
		    vec3 uv0 = floor(mod(uv, res)) * s;
		    vec3 uv1 = floor(mod(uv + vec3(1.0), res)) * s;
		    
		    vec3 f = fract(uv);
		    f = f * f * (3.0 - 2.0 * f);
		
		    vec4 v = vec4(uv0.x + uv0.y + uv0.z, uv1.x + uv0.y + uv0.z,
		                  uv0.x + uv1.y + uv0.z, uv1.x + uv1.y + uv0.z);
		
		    vec4 r = fract(sin(v * 1e-1) * 1e3);
		    float r0 = mix(mix(r.x, r.y, f.x), mix(r.z, r.w, f.x), f.y);
		
		    r = fract(sin((v + uv1.z - uv0.z) * 1e-1) * 1e3);
		    float r1 = mix(mix(r.x, r.y, f.x), mix(r.z, r.w, f.x), f.y);
			
		   	f1 = mix(r0, r1, f.z) * 2.0 - 1.0;
			n_out12p0 += (1.5 / power) * f1;
		}
		
		n_out34p0 = n_out12p0;
	}


// VectorCompose:59
	vec3 n_out59p0 = vec3(n_out34p0, n_out34p0, n_out34p0);


	vec4 n_out50p0;
// Texture2D:50
	n_out50p0 = texture(Texture1, UV);


	vec4 n_out49p0;
// Texture2D:49
	n_out49p0 = texture(Texture2, UV);


// Input:57
	float n_out57p0 = TIME;


// FloatParameter:52
	float n_out52p0 = Mix_Speed;


// FloatOp:53
	float n_out53p0 = n_out57p0 * n_out52p0;


// FloatFunc:51
	float n_out51p0 = sin(n_out53p0);


// MultiplyAdd:54
	float n_in54p1 = 0.50000;
	float n_in54p2 = 0.50000;
	float n_out54p0 = fma(n_out51p0, n_in54p1, n_in54p2);


// Mix:55
	float n_out55p0 = mix(n_out50p0.x, n_out49p0.x, n_out54p0);


// Mix:58
	vec3 n_out58p0 = mix(n_out60p0, n_out59p0, vec3(n_out55p0));


// Output:0
	COLOR.rgb = n_out58p0;


}
"
