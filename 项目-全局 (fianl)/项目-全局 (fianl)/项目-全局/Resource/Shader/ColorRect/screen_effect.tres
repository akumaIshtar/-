[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 BackgroundColor : source_color;
uniform vec4 Color1 : source_color;
uniform vec4 Color2 : source_color;
uniform sampler2D Texture1;
uniform sampler2D Texture2;
uniform float Mix_Speed;
uniform float Progress;
uniform float Feather_Width : hint_range(0.0, 1.0);



void fragment() {
// ColorParameter:29
	vec4 n_out29p0 = BackgroundColor;


// ColorParameter:15
	vec4 n_out15p0 = Color1;


// ColorParameter:18
	vec4 n_out18p0 = Color2;


	vec4 n_out22p0;
// Texture2D:22
	n_out22p0 = texture(Texture1, UV);


	vec4 n_out21p0;
// Texture2D:21
	n_out21p0 = texture(Texture2, UV);


// Input:25
	float n_out25p0 = TIME;


// FloatParameter:28
	float n_out28p0 = Mix_Speed;


// FloatOp:26
	float n_out26p0 = n_out25p0 * n_out28p0;


// FloatFunc:23
	float n_out23p0 = sin(n_out26p0);


// MultiplyAdd:24
	float n_in24p1 = 0.50000;
	float n_in24p2 = 0.50000;
	float n_out24p0 = fma(n_out23p0, n_in24p1, n_in24p2);


// Mix:20
	float n_out20p0 = mix(n_out22p0.x, n_out21p0.x, n_out24p0);


// Mix:16
	vec4 n_out16p0 = mix(n_out15p0, n_out18p0, vec4(n_out20p0));
	float n_out16p4 = n_out16p0.a;


// Input:11
	vec2 n_out11p0 = UV;


// FloatParameter:12
	float n_out12p0 = Progress;


// FloatParameter:13
	float n_out13p0 = Feather_Width;


// FloatConstant:14
	float n_out14p0 = 3.141590;


	float n_out7p0;
	float n_out7p1;
// Expression:7
	n_out7p0 = 0.0;
	n_out7p1 = 0.0;
	{
		float dis = max(abs(n_out11p0.x - 0.5), abs(n_out11p0.y - 0.5)) * 2.0;
		if (dis < n_out12p0 - n_out13p0){
			n_out7p0 = 0.0;
		}else if (dis > n_out12p0 + n_out13p0){
			n_out7p0 = 1.0;
		}else{
			n_out7p0 = (sin((dis - n_out12p0) * n_out14p0 / (n_out13p0 * 2.0)) + 1.0)/2.0;
		}
	}


// FloatOp:27
	float n_out27p0 = min(n_out16p4, n_out7p0);


// Mix:31
	vec4 n_out31p0 = mix(n_out29p0, n_out16p0, vec4(n_out27p0));


// VectorDecompose:32
	float n_out32p0 = n_out31p0.x;
	float n_out32p1 = n_out31p0.y;
	float n_out32p2 = n_out31p0.z;
	float n_out32p3 = n_out31p0.w;


// VectorCompose:33
	vec3 n_out33p0 = vec3(n_out32p0, n_out32p1, n_out32p2);


// Output:0
	COLOR.rgb = n_out33p0;
	COLOR.a = n_out32p3;


}
