code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D Texture2DParameter;
uniform sampler2D Texture2DParameter2;
uniform sampler2D Texture1;
uniform sampler2D Texture2;



void fragment() {
	vec4 n_out17p0;
// Texture2D:17
	n_out17p0 = texture(Texture2DParameter, UV);


	vec4 n_out16p0;
// Texture2D:16
	n_out16p0 = texture(Texture2DParameter2, UV);


	vec4 n_out10p0;
// Texture2D:10
	n_out10p0 = texture(Texture1, UV);


	vec4 n_out9p0;
// Texture2D:9
	n_out9p0 = texture(Texture2, UV);


// Input:11
	float n_out11p0 = TIME;


// FloatFunc:12
	float n_out12p0 = sin(n_out11p0);


// MultiplyAdd:13
	float n_in13p1 = 0.50000;
	float n_in13p2 = 0.50000;
	float n_out13p0 = fma(n_out12p0, n_in13p1, n_in13p2);


// Mix:8
	float n_out8p0 = mix(n_out10p0.x, n_out9p0.x, n_out13p0);


// Mix:3
	vec3 n_out3p0 = mix(vec3(n_out17p0.xyz), vec3(n_out16p0.xyz), vec3(n_out8p0));


// Output:0
	COLOR.rgb = n_out3p0;


}
"
